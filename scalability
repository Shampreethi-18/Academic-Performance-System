import java.io.*;
import java.util.*;

class Evaluation implements Serializable {
        String studentId;
            String name;
                int m1, m2, m3;
                    double average;
                        String grade;

                            Evaluation(String studentId, String name, int m1, int m2, int m3) {
                                        this.studentId = studentId;
                                                this.name = name;
                                                        this.m1 = m1;
                                                                this.m2 = m2;
                                                                        this.m3 = m3;
                                                                                calculate();
                            }

                                void calculate() {
                                            int total = m1 + m2 + m3;
                                                    average = total / 3.0;

                                                            if (average >= 85) grade = "A";
                                                                    else if (average >= 70) grade = "B";
                                                                            else if (average >= 50) grade = "C";
                                                                                    else grade = "Fail";
                                }

                                    void display() {
                                                System.out.println(studentId + " | " + name +
                                                                " | Avg: " + average + " | Grade: " + grade);
                                    }
}

class DataManager {
        private static final String FILE_NAME = "evaluation.dat";

            // Save data
                public static void save(List<Evaluation> list) {
                            try (ObjectOutputStream oos =
                                                 new ObjectOutputStream(new FileOutputStream(FILE_NAME))) {
                                                                 oos.writeObject(list);
                                                 } catch (IOException e) {
                                                                 System.out.println("Error saving data");
                                                 }
                }

                    // Load data
                        public static List<Evaluation> load() {
                                    try (ObjectInputStream ois =
                                                         new ObjectInputStream(new FileInputStream(FILE_NAME))) {
                                                                         return (List<Evaluation>) ois.readObject();
                                                         } catch (Exception e) {
                                                                         return new ArrayList<>();
                                                         }
                        }
}

